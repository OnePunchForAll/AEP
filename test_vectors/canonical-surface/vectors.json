    {
      "category": "trailing_newline",
      "description": "Canonical JSONL file MUST end with exactly one LF; no CRLF; no extra trailing whitespace.",
      "expected_file_bytes": "{\"a\":1}\n{\"a\":2}\n",
      "expected_outcome": "ACCEPT_TRAILING_LF",
      "id": "V026",
      "input_lines": [
