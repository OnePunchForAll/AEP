{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divomni.org/aep/schemas/event.schema.json",
  "title": "AEP Write Event",
  "type": "object",
  "required": [
    "id",
    "type",
    "op",
    "actor",
    "target",
    "pre_state_hash",
    "post_state_hash",
    "rationale",
    "created_at"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^event:"
    },
    "type": {
      "const": "WriteEvent"
    },
    "op": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "pre_state_hash": {
      "type": "string"
    },
    "post_state_hash": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  }
}
