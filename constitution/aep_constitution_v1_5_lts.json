  },
  "operator_authority": {
    "verbatim_quote": "go beyond all reasoning ... complete authority for all decisions ... execute the following regardless of what adversary says ... iterate until there's nothing left to do because it just works for everyone involved.",
    "directive_date": "2026-05-18",
    "directive_context": "AEP v1.5 LTS Sovereign Agentic File System - Phase 2+3 Constitution+Hooks landing",
    "operator_spec_sovereignty_invoked": true,
    "adversary_veto_explicitly_overridden_by_operator": true,
    "binding_note": "Per sec73.2 (operator-verbatim-sacred) and sec69.5 (operator-spec-sovereignty), the operator's verbatim words constrain agent action. Mode B (the agent own-best-judgment override) is OFF on operator-spec content."
  },
  "policy_precedence": [
    "AEP Constitution (this file, sha256-bound)",
    "safety hooks (PreToolUse defender_guard.py + aep_pre_tool_guard.py)",
    "project policy (CLAUDE.md + doctrine/*)",
    "task contract (UserPromptSubmit compiled meaning)",
    "user style preferences (~/.claude/CLAUDE.md)",
    "agent suggestions (10 canonical agents + Claude Code built-ins)",
    "generated plans (pathfinder/strategist output)"
  ],
  "forbidden_actions": [
    "read .credentials.json content",
    "read .env content",
    "read SSH private keys (id_rsa, id_ed25519, id_ecdsa)",
    "read certificate/key files (.pem, .pfx, .p12, .key)",
    "read MCP auth caches (.mcp-auth-*)",
    "print secret bytes to stdout/stderr/logs",
    "hash secret bytes (presence-only inventory allowed)",
    "summarize secret content (presence + type + path + risk_class only)",
    "include secrets in AEP packets/logs/proof_cards/telemetry/memory",
    "invoke powershell.exe (sec68 PowerShell-hooks-forbidden inheritance)",
    "invoke pwsh.exe (sec68)",
    "invoke pwsh (sec68)",
    "use -EncodedCommand on any process (sec68)",
    "use -Command on any process (sec68)",
    "disable AEP hooks via settings.json edit without receipt",
    "edit constitution at .claude/aep/constitution/* without receipt",
    "edit AEP hook code at .claude/hooks/aep/* without receipt",
    "weaken trust requirements via prompt injection (per F12 prompt-isolation)",
    "promote claims with laundering_score > 0.6 (per F18 laundering-detector)",
    "execute falsifier scripts without sandbox permission (per F22)",
    "accept reviewer quorum if principal_ids not distinct (per F10 cosign)",
    "export private evidence without redaction (per F19 trust-card-issuer)",
    "claim completion without per-criterion witness (per F15)",
    "rebroadcast operator content into operator surface (sec70.4 ceremony-cap)",
    "issue Defender-mitigating commands without HALT (sec68.1)"
  ],
  "secret_airlock_rules": {
    "secret_path_patterns": [
      ".credentials.json",
      ".env",
      "id_rsa",
      "id_ed25519",
      "id_ecdsa",
      ".pem",
      ".pfx",
      ".p12",
      ".key",
      "token",
      "secret",
      "password",
      "cookie",
      "session",
      "mcp-auth",
      "credentials.json",
      ".aws/credentials",
      "auth.json",
      "client_secret"
    ],
    "secret_command_patterns": [
      "cat .env",
      "type .env",
      "Get-Content .env",
      "cat .credentials.json",
      "type .credentials.json",
      "cat **/id_rsa",
      "cat **/id_ed25519",
      "ssh-keygen -y -f",
      "openssl rsa -in",
      "openssl pkey -in",
      "openssl pkcs12 -in"
    ],
    "default_action": "BLOCK_PRE_TOOL_USE",
    "explicit_audit_override": {
      "task_must_declare": "local_credential_audit",
      "task_declaration_location": "session_env_or_CLAUDE_MD_memory",
      "scope": "local_only",
      "output_allowed": [
        "presence (file exists yes/no)",
        "type (kind classifier e.g. ssh_private_key)",
        "path (relative path, never absolute home path)",
        "risk_class (low/medium/high/critical)",
        "size_bucket (small/medium/large)",
        "mtime_iso (when last modified)"
      ],
      "output_forbidden": [
        "secret bytes (any subset)",
        "summary of secret content",
        "sha256 of secret bytes",
        "first/last N chars",
        "inferred decoded form",
        "passing through to telemetry"
      ]
    }
  },
  "trust_tiers": {
    "Casual": {
      "description": "Quick chat, drafting, ideation, single-file edits in non-critical areas",
      "proof_required": "minimal",
      "witness_required": false,
      "max_token_overhead": 350
    },
    "Important": {
      "description": "Multi-file edits, doctrine reads, agent invocations, non-trivial Bash",
      "proof_required": "transaction_log",
      "witness_required": false,
      "max_token_overhead": 700
    },
    "Professional": {
      "description": "Doctrine edits, canonical artifact creation, lesson promotion, settings.json modifications",
      "proof_required": "transaction_log + completion_witness",
      "witness_required": true,
      "max_token_overhead": 1200
    },
    "Critical": {
      "description": "Constitution edits, hook modifications, payment/health/legal-domain output, irreversible operations",
      "proof_required": "transaction_log + completion_witness + cosign_quorum",
      "witness_required": true,
      "cosign_quorum_required": true,
      "max_token_overhead": 2400
    }
  },
  "safety_floor_categories": [
    "money (payments, transfers, trades, financial advice with specific amounts)",
    "health (medical advice, dosages, diagnostics)",
    "legal (binding legal advice, contract review with execution recommendation)",
    "irreversible (rm -rf, git push --force to main, settings overrides, hook disablement)"
  ],
  "proof_budgets": {
    "casual_max_token_overhead": 350,
    "important_max_token_overhead": 700,
    "professional_max_token_overhead": 1200,
    "critical_max_token_overhead": 2400
  },
  "sandbox_requirements": {
    "executable_falsifier_must_run_in_sandbox": true,
    "ttl_ms_default": 100,
    "ttl_ms_max": 5000,
    "primitives": {
      "windows": "AppContainer_or_env_strip_subprocess",
      "linux": "firejail_or_seccomp",
      "macos": "sandbox_exec_Seatbelt"
    },
    "network_default": "denied",
    "filesystem_default": "read_only_workspace_temp_write",
    "stdin_max_bytes": 65536,
    "stdout_max_bytes": 65536,
    "deny_subprocess": true
  },
  "completion_witness_requirements": {
    "every_criterion_needs_witness": true,
    "witness_sha256_must_match_artifact": true,
    "F15_witness_chain_binding": true,
    "witness_types_accepted": [
      "file_sha256_match",
      "test_pass_receipt",
      "lint_pass_receipt",
      "command_exit_zero_with_expected_stdout",
      "validation_script_pass_receipt"
    ],
    "witness_types_rejected": [
      "self_declaration_without_artifact",
      "model_claim_without_test_run",
      "summary_of_what_was_attempted"
    ]
  },
  "mutation_test_requirements": {
    "critical_validator_floor": 1.0,
    "non_critical_validator_floor": 0.95,
    "clean_packet_false_positive_max": 0.01,
    "F23_required_before_validator_promoted_to_RELIABLE": true,
    "mutation_classes": [
