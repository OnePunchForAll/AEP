{
  "$id": "aep:regexical-memory:0.1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "A source-bound mnemonic/regex cue with recall payload and spaced-repetition state for AEP packets.",
  "properties": {
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "created_by_agent": {
      "type": "string"
    },
    "creation_mode": {
      "enum": [
        "birth_event",
        "retrofit_existing_packet",
        "retrofit_example_for_existing_packet"
      ],
      "type": "string"
    },
    "cue_class": {
      "enum": [
        "role_object_pair",
        "role_failure_pair",
        "mechanism_boundary_pair",
        "source_claim_pair"
      ],
      "type": "string"
    },
    "cue_phrase": {
      "maxLength": 160,
      "minLength": 3,
      "type": "string"
    },
    "cue_words": {
      "items": {
        "pattern": "^[a-z0-9][a-z0-9-]{1,63}$",
        "type": "string"
      },
      "maxItems": 4,
      "minItems": 2,
      "type": "array"
    },
    "id": {
      "pattern": "^rxmem:",
      "type": "string"
    },
    "integrity": {
      "additionalProperties": true,
      "properties": {
        "canonicalization": {
          "type": "string"
        },
        "cue_record_sha256_excluding_integrity": {
          "pattern": "^sha256:",
          "type": "string"
        },
        "receipt_required_for_install": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "packet_id": {
      "type": "string"
    },
    "portable_regex_subset": {
      "type": "string"
    },
    "profile": {
      "pattern": "^aep:",
      "type": "string"
    },
    "recall_payload": {
      "additionalProperties": true,
      "properties": {
        "distinguishers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "failure_prevented": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "kind": {
          "type": "string"
        },
        "minimum_recall_fields": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "one_sentence": {
          "maxLength": 500,
          "type": "string"
        },
        "owner_agent": {
          "type": "string"
        },
        "stop_condition": {
          "type": "string"
        },
        "when_to_open_full_file": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "kind",
        "owner_agent",
        "one_sentence",
        "minimum_recall_fields",
        "stop_condition"
      ],
      "type": "object"
    },
    "regex": {
      "additionalProperties": false,
      "properties": {
        "dialect": {
          "enum": [
            "portable-rxmem-v1"
          ],
          "type": "string"
        },
        "flags": {
          "items": {
            "enum": [
              "case_insensitive",
              "multiline"
            ],
            "type": "string"
          },
          "type": "array"
        },
        "forbidden_features": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "patterns": {
          "items": {
            "maxLength": 200,
            "type": "string"
          },
          "maxItems": 8,
          "minItems": 2,
          "type": "array"
        }
      },
      "required": [
        "dialect",
        "flags",
        "patterns",
        "forbidden_features"
      ],
      "type": "object"
    },
    "schema_version": {
      "const": "aep-regexical-memory-0.1"
    },
    "source_bindings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "basis_claim_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "path": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          },
          "source_sha256": {
            "pattern": "^sha256:",
            "type": "string"
          },
          "span_id": {
            "type": "string"
          }
        },
        "required": [
          "source_id",
          "path",
          "source_sha256"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "srs": {
      "additionalProperties": true,
      "properties": {
        "algorithm": {
          "enum": [
            "SM2_LITE_BOOTSTRAP",
            "FSRS_LITE_AFTER_HISTORY",
            "FIXED_INTERVAL_BOOTSTRAP"
          ],
          "type": "string"
        },
        "due_at": {
          "format": "date-time",
          "type": "string"
        },
        "ease_factor": {
          "minimum": 1.3,
          "type": "number"
        },
        "interval_days": {
          "minimum": 0,
          "type": "number"
        },
        "lapses": {
          "minimum": 0,
          "type": "integer"
        },
        "minimum_ease_factor": {
          "minimum": 1.0,
          "type": "number"
        },
        "next_reviews_seed": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "repetitions": {
          "minimum": 0,
          "type": "integer"
        },
        "review_scale": {
          "enum": [
            "0_to_5",
            "again_hard_good_easy"
          ],
          "type": "string"
        }
      },
      "required": [
        "algorithm",
        "review_scale",
        "ease_factor",
        "minimum_ease_factor",
        "repetitions",
        "lapses",
        "interval_days",
        "due_at"
      ],
      "type": "object"
    },
    "status": {
      "enum": [
        "active",
        "superseded",
        "quarantined",
        "proposed_example_not_installed"
      ],
      "type": "string"
    },
    "type": {
      "const": "RegexicalCue"
    },
    "validation": {
      "additionalProperties": true,
      "properties": {
        "collision_scan": {
          "type": "object"
        },
        "compile_and_match_results": {
          "type": "object"
        },
        "expected_recall_test": {
          "type": "object"
        },
        "quorum_target": {
          "type": "string"
        }
      },
      "required": [
        "quorum_target",
        "expected_recall_test"
      ],
      "type": "object"
    }
  },
  "required": [
    "type",
    "schema_version",
    "id",
    "packet_id",
    "profile",
    "created_at",
    "created_by_agent",
    "cue_words",
    "cue_phrase",
    "regex",
    "source_bindings",
    "recall_payload",
    "srs",
    "validation"
  ],
  "title": "AEP Regexical Memory Cue",
  "type": "object"
}