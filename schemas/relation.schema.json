{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divomni.org/aep/schemas/relation.schema.json",
  "title": "AEP Relation",
  "type": "object",
  "required": [
    "id",
    "type",
    "subject",
    "predicate",
    "object",
    "basis_claims",
    "inference_label",
    "created_at"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^rel:[A-Za-z0-9._:-]+$"
    },
    "type": {
      "const": "Relation"
    },
    "subject": {
      "type": "string"
    },
    "predicate": {
      "type": "string"
    },
    "object": {
      "type": "string"
    },
    "basis_claims": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^claim:"
      }
    },
    "inference_label": {
      "enum": [
        "explicit_in_source",
        "derived_from_claims",
        "architectural_inference",
        "speculative_design"
      ]
    },
    "created_at": {
      "type": "string"
    }
  }
}
